@using SMS.Shared.Helpers
@model StudentReportCardDto
@{
    ViewData["Title"] = "کارنامه " + Model.FullName;
    var termId = ViewContext.RouteData.Values["termId"];
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-clipboard-data"></i>کارنامه: @Model.FullName</h1>
        <div class="subtitle">@Model.SchoolName | @Model.ClassroomName | @Model.TermName</div>
    </div>
    <div>
        <a asp-action="ReportCardPdf" asp-route-studentId="@Model.StudentId" asp-route-termId="@termId" target="_blank" class="btn btn-danger"><i class="bi bi-file-pdf"></i> خروجی PDF</a>
        <a asp-controller="Export" asp-action="StudentReportCardExcel" asp-route-studentId="@Model.StudentId" asp-route-termId="@termId" class="btn btn-success"><i class="bi bi-bar-chart"></i> خروجی Excel</a>
        <button class="btn btn-info" onclick="window.print()"><i class="bi bi-printer"></i> پرینت</button>
        <a asp-action="Dashboard" asp-route-studentId="@Model.StudentId" class="btn btn-secondary">بازگشت</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table class="data-table" style="margin-bottom:16px">
            <tr>
                <th>نام:</th><td>@Model.FullName</td>
                <th>نام پدر:</th><td>@Model.FatherName</td>
            </tr>
            <tr>
                <th>کد دانش‌آموزی:</th><td>@Model.StudentCode</td>
                <th>پایه:</th><td>@Model.GradeName</td>
            </tr>
        </table>

        <h3 class="section-title">📚 نمرات دروس</h3>
        <table class="data-table">
            <thead><tr><th>درس</th><th>ضریب</th><th>نمره</th><th>وضعیت</th><th>معلم</th></tr></thead>
            <tbody>
                @foreach (var s in Model.Subjects)
                {
                    <tr>
                        <td><strong>@s.SubjectName</strong></td>
                        <td>@s.Coefficient</td>
                        <td>
                            @if (s.IsDescriptive) { <span class="badge badge-info">@s.DescriptiveLabel</span> }
                            else { <strong>@PersianDate.ToPersianDigits((s.NumericScore ?? 0).ToString("0.##"))</strong> }
                        </td>
                        <td>
                            @switch (s.IsPassed)
                            {
                                case true: <span class="badge badge-success">قبول</span> break;
                                case false: <span class="badge badge-danger">مردود</span> break;
                                default: <span class="text-muted">—</span> break;
                            }
                        </td>
                        <td>@s.TeacherName</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="row" style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:16px">
            <div class="card" style="background:#e0f2fe">
                <div class="card-body">
                    <h3><i class="bi bi-bar-chart-line-fill"></i>خلاصه</h3>
                    <p><strong>معدل کل:</strong> <span style="font-size:24px; color:#0c5474">@PersianDate.ToPersianDigits((Model.GPA ?? 0).ToString("0.000"))</span></p>
                    <p><strong>نمره انضباط:</strong> @PersianDate.ToPersianDigits((Model.DisciplineScore ?? 0).ToString("0.##"))</p>
                </div>
            </div>
            <div class="card" style="background:#fef3c7">
                <div class="card-body">
                    <h3><i class="bi bi-calendar3"></i>حضور و غیاب</h3>
                    <p><strong>غیبت:</strong> @PersianDate.ToPersianDigits(Model.TotalAbsences.ToString())</p>
                    <p><strong>تاخیر:</strong> @PersianDate.ToPersianDigits(Model.TotalTardies.ToString())</p>
                </div>
            </div>
        </div>
    </div>
</div>
