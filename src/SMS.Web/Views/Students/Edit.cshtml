@model StudentUpdateDto
@{ ViewData["Title"] = "ویرایش دانش‌آموز"; }

<div class="card">
    <div class="card-header"><h2>✏️ ویرایش دانش‌آموز</h2></div>
    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StudentId" />
        <input type="hidden" asp-for="PersonId" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col"><div class="form-group"><label>نام *</label><input asp-for="FirstName" class="form-control" /></div></div>
            <div class="col"><div class="form-group"><label>نام خانوادگی *</label><input asp-for="LastName" class="form-control" /></div></div>
            <div class="col"><div class="form-group"><label>نام پدر</label><input asp-for="FatherName" class="form-control" /></div></div>
        </div>

        <div class="row">
            <div class="col"><div class="form-group"><label>کد ملی</label><input asp-for="NationalCode" class="form-control" maxlength="10" /></div></div>
            <div class="col">
                <div class="form-group"><label>جنسیت</label>
                    <select asp-for="Gender" class="form-control">
                        <option value="M">پسر</option><option value="F">دختر</option>
                    </select>
                </div>
            </div>
            <div class="col"><div class="form-group"><label>تاریخ تولد</label><input asp-for="BirthDate" class="form-control" type="date" /></div></div>
            <div class="col"><div class="form-group"><label>موبایل</label><input asp-for="Mobile" class="form-control" /></div></div>
        </div>

        <div class="form-group"><label>آدرس</label><textarea asp-for="Address" class="form-control" rows="2"></textarea></div>

        <div class="row">
            <div class="col"><div class="form-group"><label>کد دانش‌آموزی *</label><input asp-for="StudentCode" class="form-control" /></div></div>
            <div class="col">
                <div class="form-group"><label>وضعیت</label>
                    <select asp-for="IsActive" class="form-control">
                        <option value="true">فعال</option><option value="false">غیرفعال</option>
                    </select>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-success">💾 ذخیره تغییرات</button>
        <a asp-action="Index" class="btn" style="background:#95a5a6;color:white">انصراف</a>
    </form>
</div>
