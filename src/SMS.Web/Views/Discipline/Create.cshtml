@model DisciplinaryRecordCreateDto
@{ ViewData["Title"] = "ثبت رکورد انضباطی"; }

<div class="page-header"><h1>➕ ثبت رکورد انضباطی</h1></div>

<div class="card">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            }

            <div class="form-row">
                <div class="form-group">
                    <label>کد دانش‌آموز *</label>
                    <input asp-for="StudentId" class="form-control" type="number" required />
                    @if (ViewBag.StudentName != null) { <small class="text-muted">@ViewBag.StudentName</small> }
                </div>
                <div class="form-group">
                    <label>نوع *</label>
                    <select asp-for="TypeId" class="form-control" id="typeSelect" required>
                        <option value="">انتخاب</option>
                        <optgroup label="🎁 تشویق">
                            @foreach (var t in ((List<DisciplinaryTypeDto>)ViewBag.Types).Where(x => x.Category == "R"))
                            {
                                <option value="@t.TypeId" data-score="@t.DefaultScoreImpact">@t.Name</option>
                            }
                        </optgroup>
                        <optgroup label="⚠ تنبیه">
                            @foreach (var t in ((List<DisciplinaryTypeDto>)ViewBag.Types).Where(x => x.Category == "P"))
                            {
                                <option value="@t.TypeId" data-score="@t.DefaultScoreImpact">@t.Name</option>
                            }
                        </optgroup>
                    </select>
                </div>
                <div class="form-group">
                    <label>تاریخ</label>
                    <input asp-for="RecordDate" class="form-control" type="date" />
                </div>
            </div>

            <div class="form-group">
                <label>توضیحات *</label>
                <textarea asp-for="Description" class="form-control" rows="3" required placeholder="شرح کامل رخداد"></textarea>
            </div>
            <div class="form-group">
                <label>اقدام انجام شده</label>
                <textarea asp-for="ActionTaken" class="form-control" rows="2"></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>تاثیر در نمره انضباط</label>
                    <input asp-for="ScoreImpact" class="form-control" type="number" step="0.25" id="scoreImpact" />
                    <small class="text-muted">با انتخاب نوع، پیش‌فرض پر می‌شود</small>
                </div>
                <div class="form-group">
                    <label>اطلاع‌رسانی به اولیا</label>
                    <select asp-for="NotifyParent" class="form-control">
                        <option value="false">خیر</option>
                        <option value="true">بله</option>
                    </select>
                </div>
            </div>

            <button class="btn btn-success">💾 ثبت</button>
            <a asp-action="Index" class="btn btn-secondary">انصراف</a>
        </form>
    </div>
</div>

<script>
    document.getElementById('typeSelect').addEventListener('change', function () {
        var score = this.options[this.selectedIndex].dataset.score;
        if (score) document.getElementById('scoreImpact').value = score;
    });
</script>
