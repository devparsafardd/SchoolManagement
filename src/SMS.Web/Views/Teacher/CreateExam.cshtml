@using SMS.Application.DTOs
@model ExamCreateDto
@{ ViewData["Title"] = "ایجاد آزمون جدید"; }

<div class="page-header"><h1>➕ ایجاد آزمون جدید</h1></div>

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="CreateExam">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ClassSubjectId" />
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger"></div>
            }

            <div class="form-group">
                <label>عنوان آزمون *</label>
                <input asp-for="Title" class="form-control" placeholder="مثلاً: آزمون فصل دوم" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>نوع آزمون *</label>
                    <select asp-for="ExamTypeId" class="form-control" required>
                        <option value="">انتخاب</option>
                        @foreach (var t in (List<ExamTypeDto>)ViewBag.ExamTypes)
                        {
                            <option value="@t.ExamTypeId" data-weight="@t.DefaultWeight">@t.Name</option>
                        }
                    </select>
                    <span asp-validation-for="ExamTypeId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>نوبت *</label>
                    <select asp-for="TermId" class="form-control" required>
                        <option value="">انتخاب</option>
                        @foreach (var t in (List<LookupDto>)ViewBag.Terms)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                    <span asp-validation-for="TermId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>تاریخ آزمون</label>
                    <input asp-for="ExamDate" id="examDateInput" type="hidden" />
                    <input id="examDatePersian" class="form-control persian-date" placeholder="1404/03/15" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group"><label>نمره کل</label><input asp-for="MaxScore" class="form-control" type="number" step="0.5" /></div>
                <div class="form-group"><label>وزن در نمره ترم</label><input asp-for="Weight" class="form-control" type="number" step="0.5" /></div>
                <div class="form-group"><label>مدت زمان (دقیقه)</label><input asp-for="DurationMinutes" class="form-control" type="number" /></div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>نوع نمره‌دهی</label>
                    <select asp-for="IsDescriptive" class="form-control" id="descSelect" onchange="toggleScale()">
                        <option value="false">عددی</option>
                        <option value="true">توصیفی</option>
                    </select>
                </div>
                <div class="form-group" id="scaleBox" style="display:@(Model.IsDescriptive ? "block" : "none")">
                    <label>مقیاس توصیفی *</label>
                    <select asp-for="GradeScaleId" class="form-control">
                        <option value="">انتخاب کنید</option>
                        @foreach (var gs in (List<GradeScaleDto>)ViewBag.GradeScales)
                        {
                            <option value="@gs.GradeScaleId">@gs.Name</option>
                        }
                    </select>
                    <span asp-validation-for="GradeScaleId" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group"><label>توضیحات</label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>

            <button type="submit" class="btn btn-success">💾 ایجاد و ورود به صفحه نمرات</button>
            <a asp-action="Exams" asp-route-classSubjectId="@Model.ClassSubjectId" class="btn btn-secondary">انصراف</a>
        </form>
    </div>
</div>

<script>
    function toggleScale() {
        var sel = document.getElementById('descSelect');
        var box = document.getElementById('scaleBox');
        // مقدار از string می‌آید: "true" یا "false" (case-insensitive)
        var isDesc = sel.value.toLowerCase() === 'true';
        box.style.display = isDesc ? 'block' : 'none';
        var scaleInput = box.querySelector('select');
        if (scaleInput) scaleInput.required = isDesc;
    }
    // اجرا روی Load برای حالت بازگشت با خطا
    document.addEventListener('DOMContentLoaded', toggleScale);
</script>


@section Scripts {
    <script>
        $(document).ready(function () {
            var initDate = '@(Model.ExamDate.ToString("yyyy-MM-dd"))';
            $('#examDatePersian').smsPersianDatePicker({
                initialValue: false,
                onSelect: function (unix) {
                    var pd = new persianDate(unix).toCalendar('gregorian').toLocale('en');
                    $('#examDateInput').val(pd.format('YYYY-MM-DD'));
                }
            });
            // پر کردن مقدار اولیه به شمسی
            if (initDate) {
                var d = new persianDate(new Date(initDate)).format('YYYY/MM/DD');
                $('#examDatePersian').val(d);
                $('#examDateInput').val(initDate);
            }
        });
    </script>
}
