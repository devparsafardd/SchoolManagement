@using SMS.Application.DTOs
@using SMS.Shared.Helpers
@model MessageDto
@{ ViewData["Title"] = Model.Subject ?? "پیام"; }

<div class="page-header">
    <h1><i class="bi bi-envelope-fill"></i>@(string.IsNullOrEmpty(Model.Subject) ? "(بدون موضوع)" : Model.Subject)</h1>
    <div>
        <a class="btn btn-primary" asp-action="Compose" asp-route-replyTo="@Model.MessageId"><i class="bi bi-arrow-return-left"></i> پاسخ</a>
        <a class="btn btn-outline" asp-action="Index"><i class="bi bi-download"></i> بازگشت</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div style="border-bottom:1px solid #eee; padding-bottom:10px; margin-bottom:14px">
            <p><strong>از:</strong> @Model.FromUserName</p>
            <p><strong>به:</strong> @Model.ToUserName</p>
            <p><strong>تاریخ:</strong> @PersianDate.ToPersianLong(Model.SentAt)</p>
            @if (!string.IsNullOrEmpty(Model.Category))
            {
                <p><strong>دسته:</strong> <span class="badge badge-info">@Model.Category</span></p>
            }
        </div>
        <div style="white-space:pre-wrap; line-height:1.8">@Model.Body</div>
    </div>
</div>
