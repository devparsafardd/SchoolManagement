@using SMS.Shared.Helpers
@model PagedResult<AnnouncementDto>
@{ ViewData["Title"] = "اعلان‌ها"; }

<div class="page-header">
    <h1>📢 اعلان‌ها و اطلاعیه‌ها</h1>
    <a asp-action="Create" class="btn btn-success">➕ اعلان جدید</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="data-table">
            <thead><tr><th>عنوان</th><th>مخاطب</th><th>تاریخ انتشار</th><th>پایان</th><th>وضعیت</th><th></th></tr></thead>
            <tbody>
                @foreach (var a in Model.Items)
                {
                    <tr>
                        <td><strong>@a.Title</strong><br /><small class="text-muted">@(a.Body.Length > 80 ? a.Body.Substring(0, 80) + "..." : a.Body)</small></td>
                        <td><span class="badge badge-info">
                            @(a.TargetAudience switch {
                                "All" => "همه",
                                "Students" => "دانش‌آموزان",
                                "Parents" => "اولیا",
                                "Teachers" => "معلمان",
                                _ => a.TargetAudience
                            })
                        </span></td>
                        <td>@PersianDate.ToPersianDateTime(a.PublishDate)</td>
                        <td>@(a.ExpiryDate.HasValue ? PersianDate.ToPersian(a.ExpiryDate.Value) : "-")</td>
                        <td>@(a.IsActive ? Html.Raw("<span class='badge badge-success'>فعال</span>") : Html.Raw("<span class='badge badge-secondary'>غیرفعال</span>"))</td>
                        <td>
                            <form method="post" asp-action="Delete" asp-route-id="@a.AnnouncementId" style="display:inline" onsubmit="return confirm('حذف شود؟');">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-danger btn-sm">🗑</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any()) { <tr><td colspan="6" class="empty-state">اعلانی ثبت نشده</td></tr> }
            </tbody>
        </table>
    </div>
</div>
