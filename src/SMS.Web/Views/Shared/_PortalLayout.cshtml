@using System.Reflection
@{
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "کاربر";
    var initials = string.IsNullOrEmpty(fullName) ? "?" : fullName.Substring(0, Math.Min(2, fullName.Length));
    var isParent = User.IsInRole("Parent");
    var roleText = isParent ? "ولی دانش‌آموز" : "دانش‌آموز";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    // ===== پیدا کردن studentId از چندین منبع =====
    // اولویت: 1) Route 2) Query 3) ViewBag 4) Model (اگر property داشته باشد) 5) Session
    string? studentId = ViewContext.RouteData.Values["studentId"]?.ToString();
    if (string.IsNullOrEmpty(studentId))
        studentId = Context.Request.Query["studentId"].ToString();
    if (string.IsNullOrEmpty(studentId) && ViewBag.StudentId != null)
        studentId = ViewBag.StudentId.ToString();
    if (string.IsNullOrEmpty(studentId) && Model != null)
    {
        var prop = Model.GetType().GetProperty("StudentId");
        if (prop != null)
        {
            var val = prop.GetValue(Model);
            if (val != null) studentId = val.ToString();
        }
    }
    if (string.IsNullOrEmpty(studentId))
        studentId = Context.Session.GetString("PortalStudentId");

    // ذخیره در Session برای استفاده در صفحات بعدی
    if (!string.IsNullOrEmpty(studentId))
        Context.Session.SetString("PortalStudentId", studentId);

    // ===== termId پیش‌فرض =====
    var termId = ViewContext.RouteData.Values["termId"]?.ToString();
    if (string.IsNullOrEmpty(termId))
        termId = Context.Request.Query["termId"].ToString();
    if (string.IsNullOrEmpty(termId))
        termId = "1";
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل @roleText</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- اعمال تم قبل از رندر -->
    <script>
        (function() {
            var t = (document.cookie.match(/sms\.theme=([^;]+)/) || [])[1] || 'indigo';
            var m = (document.cookie.match(/sms\.mode=([^;]+)/) || [])[1] || 'light';
            document.documentElement.setAttribute('data-theme', t);
            document.documentElement.setAttribute('data-mode', m);
        })();
    </script>
</head>
<body>
    <header class="topbar">
        <div class="topbar-left">
            <button class="sidebar-toggle" onclick="smsToggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            <div class="brand">
                <span class="brand-icon"><i class="bi bi-mortarboard-fill"></i></span>
                <span class="brand-text">پنل @roleText</span>
            </div>
        </div>
        <div class="topbar-right">
            @await Html.PartialAsync("_ThemeSwitcher")
            @await Html.PartialAsync("_NotificationBell")
            <div class="user-menu" onclick="this.classList.toggle('open')">
                @await Html.PartialAsync("_UserAvatar")
                <div class="user-info">
                    <div class="user-name">@fullName</div>
                    <div class="user-role">@roleText</div>
                </div>
                <div class="user-dropdown">
                    <a asp-controller="Account" asp-action="Profile"><i class="bi bi-person-circle"></i> پروفایل من</a>
                    <a asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-lock-fill"></i> تغییر رمز</a>
                    @if (isParent)
                    {
                        <a asp-controller="Parent" asp-action="Dashboard"><i class="bi bi-arrow-repeat"></i> تغییر فرزند</a>
                    }
                    <hr />
                    <a asp-controller="Help" asp-action="Index"><i class="bi bi-question-circle"></i> راهنما</a>
                    <a asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> خروج</a>
                </div>
            </div>
        </div>
    </header>

    <aside class="sidebar">
        <nav class="menu">
            <a asp-controller="MyPortal" asp-action="Dashboard" asp-route-studentId="@studentId"
               class="menu-item @(currentAction == "Index" || currentAction == "Dashboard" ? "active" : "")">
                <i class="menu-icon bi bi-house-door-fill"></i><span class="menu-text">داشبورد</span>
            </a>

            @if (!string.IsNullOrEmpty(studentId))
            {
                <div class="menu-section">اطلاعات تحصیلی</div>
                <a asp-controller="MyPortal" asp-action="Scores" asp-route-studentId="@studentId"
                   class="menu-item @(currentAction == "Scores" ? "active" : "")">
                    <i class="menu-icon bi bi-pencil-square"></i><span class="menu-text">نمرات</span>
                </a>
                <a asp-controller="MyPortal" asp-action="Attendance" asp-route-studentId="@studentId"
                   class="menu-item @(currentAction == "Attendance" ? "active" : "")">
                    <i class="menu-icon bi bi-check-circle-fill"></i><span class="menu-text">حضور و غیاب</span>
                </a>
                <a asp-controller="MyPortal" asp-action="Discipline" asp-route-studentId="@studentId"
                   class="menu-item @(currentAction == "Discipline" ? "active" : "")">
                    <i class="menu-icon bi bi-star-fill"></i><span class="menu-text">انضباطی</span>
                </a>
                <a asp-controller="MyPortal" asp-action="ReportCard" asp-route-studentId="@studentId" asp-route-termId="@termId"
                   class="menu-item @(currentAction == "ReportCard" ? "active" : "")">
                    <i class="menu-icon bi bi-clipboard-data"></i><span class="menu-text">کارنامه</span>
                </a>

                <div class="menu-section">سایر</div>
                <a asp-controller="MyPortal" asp-action="Finance" asp-route-studentId="@studentId"
                   class="menu-item @(currentAction == "Finance" ? "active" : "")">
                    <i class="menu-icon bi bi-cash-stack"></i><span class="menu-text">شهریه</span>
                </a>
                <a asp-controller="MyPortal" asp-action="Announcements" asp-route-studentId="@studentId"
                   class="menu-item @(currentAction == "Announcements" ? "active" : "")">
                    <i class="menu-icon bi bi-megaphone-fill"></i><span class="menu-text">اعلان‌ها</span>
                </a>
                @if (!isParent)
                {
                    <a asp-controller="Homeworks" asp-action="Student"
                       class="menu-item @(currentController == "Homeworks" ? "active" : "")">
                        <i class="menu-icon bi bi-book-half"></i><span class="menu-text">تکالیف</span>
                    </a>
                }
                <a asp-controller="Messages" asp-action="Index"
                   class="menu-item @(currentController == "Messages" ? "active" : "")">
                    <i class="menu-icon bi bi-chat-dots-fill"></i><span class="menu-text">پیام‌ها</span>
                </a>
            }
            else
            {
                <!-- بدون studentId: حداقل پیام‌ها و تکالیف رو نشون بدیم -->
                <div class="menu-section">عمومی</div>
                @if (!isParent)
                {
                    <a asp-controller="Homeworks" asp-action="Student" class="menu-item">
                        <i class="menu-icon bi bi-book-half"></i><span class="menu-text">تکالیف</span>
                    </a>
                }
                <a asp-controller="Messages" asp-action="Index" class="menu-item">
                    <i class="menu-icon bi bi-chat-dots-fill"></i><span class="menu-text">پیام‌ها</span>
                </a>
            }
        </nav>
        <div class="sidebar-footer">
            <small>سیستم مدیریت مدارس</small>
        </div>
    </aside>

    <main class="main-content">
        @if (TempData["Success"] is string ok)
        {
            <div class="alert alert-success alert-dismissible">
                <span class="alert-icon">✓</span><span>@ok</span>
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger alert-dismissible">
                <span class="alert-icon">✗</span><span>@err</span>
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }
        @if (TempData["Info"] is string info)
        {
            <div class="alert alert-info alert-dismissible">
                <span class="alert-icon">ℹ</span><span>@info</span>
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }
        @RenderBody()
    </main>

    <div class="sidebar-overlay" onclick="document.body.classList.remove('sidebar-open')"></div>

    <script>
        document.addEventListener('click', function (e) {
            var menu = document.querySelector('.user-menu.open');
            if (menu && !menu.contains(e.target)) menu.classList.remove('open');
        });
        setTimeout(function () {
            document.querySelectorAll('.alert-dismissible').forEach(function (a) {
                a.style.transition = 'opacity .5s'; a.style.opacity = '0';
                setTimeout(function () { a.remove(); }, 500);
            });
        }, 5000);
    </script>
    @await Html.PartialAsync("_AdvancedScripts")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
