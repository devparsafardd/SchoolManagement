@using SMS.Shared.Helpers
@model PagedResult<StudentDto>
@{ ViewData["Title"] = "دانش‌آموزان"; }

<div class="page-header">
    <div>
        <h1><i class="bi bi-people-fill"></i>دانش‌آموزان (@PersianDate.ToPersianDigits(Model.TotalCount.ToString()))</h1>
    </div>
    <div>
        <a asp-controller="Export" asp-action="StudentsExcel" asp-route-schoolId="@ViewBag.SchoolId" asp-route-search="@ViewBag.Search" class="btn btn-success"><i class="bi bi-bar-chart"></i> Excel</a>
        <a asp-controller="Export" asp-action="StudentsPdf" asp-route-schoolId="@ViewBag.SchoolId" asp-route-search="@ViewBag.Search" target="_blank" class="btn btn-danger"><i class="bi bi-file-pdf"></i> PDF</a>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> افزودن دانش‌آموز</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="filters-bar">
            <div class="form-group">
                <label>مدرسه</label>
                <select name="schoolId" class="form-control" onchange="this.form.submit()" style="width:200px">
                    <option value="">همه</option>
                    @foreach (var s in (IEnumerable<SchoolDto>)ViewBag.Schools)
                    {
                        var sel = ViewBag.SchoolId != null && (int)ViewBag.SchoolId == s.SchoolId ? "selected" : "";
                        @Html.Raw($"<option value='{s.SchoolId}' {sel}>{s.Name}</option>")
                    }
                </select>
            </div>
            <div class="form-group">
                <label>کلاس</label>
                <select name="classroomId" class="form-control" style="width:160px">
                    <option value="">همه</option>
                    @foreach (var c in (List<ClassroomDto>)ViewBag.Classrooms)
                    {
                        var sel = ViewBag.ClassroomId != null && (int)ViewBag.ClassroomId == c.ClassroomId ? "selected" : "";
                        @Html.Raw($"<option value='{c.ClassroomId}' {sel}>{c.GradeName} - {c.Name}</option>")
                    }
                </select>
            </div>
            <div class="form-group" style="flex:1">
                <label>جستجوی سرور (نام / کد / کد ملی)</label>
                <input name="search" value="@ViewBag.Search" class="form-control" placeholder="جستجو در کل دیتابیس" />
            </div>
            <button class="btn btn-primary"><i class="bi bi-search"></i> </button>
        </form>

        <table class="data-table enhanced" id="studentsTable">
            <thead><tr><th>کد</th><th>نام</th><th>نام پدر</th><th>کلاس فعلی</th><th>مدرسه</th><th>حساب</th><th class="no-export">عملیات</th></tr></thead>
            <tbody>
                @foreach (var s in Model.Items)
                {
                    <tr>
                        <td><code>@s.StudentCode</code></td>
                        <td><strong>@s.FullName</strong></td>
                        <td>@s.FatherName</td>
                        <td>@s.CurrentClassName</td>
                        <td>@s.CurrentSchoolName</td>
                        <td>
                            @if (s.UserId.HasValue)
                            {<span class="badge badge-success" title="@s.Username">✓</span>}
                            else
                            {<span class="badge badge-warning">⚠</span>}
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@s.StudentId" class="btn btn-outline btn-sm"><i class="bi bi-eye"></i></a>
                            <a asp-controller="Analytics" asp-action="Student" asp-route-id="@s.StudentId" class="btn btn-info btn-sm" title="گزارش جامع"><i class="bi bi-bar-chart"></i></a>
                            <a asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-primary btn-sm"><i class="bi bi-pencil"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination" style="margin-top:14px">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.Page) { <span class="active">@PersianDate.ToPersianDigits(i.ToString())</span> }
                    else { <a asp-action="Index" asp-route-page="@i" asp-route-schoolId="@ViewBag.SchoolId" asp-route-classroomId="@ViewBag.ClassroomId" asp-route-search="@ViewBag.Search">@PersianDate.ToPersianDigits(i.ToString())</a> }
                }
            </div>
        }
    </div>
</div>

