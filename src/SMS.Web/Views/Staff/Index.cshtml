@using SMS.Shared.Helpers
@model PagedResult<StaffDto>
@{ ViewData["Title"] = "معلمان و کارکنان"; }

<div class="page-header">
    <div>
        <h1>👨‍🏫 معلمان و کارکنان</h1>
        <div class="subtitle">مجموع: @PersianDate.ToPersianDigits(Model.TotalCount.ToString())</div>
    </div>
    <div>
        <a asp-controller="Export" asp-action="StaffExcel" asp-route-schoolId="@ViewBag.SchoolId" asp-route-search="@ViewBag.Search" class="btn btn-success">📊 Excel</a>
        <a asp-controller="Export" asp-action="StaffPdf" asp-route-schoolId="@ViewBag.SchoolId" asp-route-search="@ViewBag.Search" target="_blank" class="btn btn-danger">📄 PDF</a>
        <a asp-action="Create" class="btn btn-primary">➕ افزودن کارمند</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="filters-bar">
            <div class="form-group">
                <label>مدرسه</label>
                <select name="schoolId" class="form-control" onchange="this.form.submit()">
                    <option value="">همه</option>
                    @foreach (var s in (IEnumerable<SchoolDto>)ViewBag.Schools)
                    {
                        var sel = ViewBag.SchoolId != null && (int)ViewBag.SchoolId == s.SchoolId ? "selected" : "";
                        @Html.Raw($"<option value='{s.SchoolId}' {sel}>{s.Name}</option>")
                    }
                </select>
            </div>
            <div class="form-group">
                <label>سمت</label>
                <select name="position" class="form-control">
                    <option value="">همه</option>
                    <option value="Teacher" selected="@(ViewBag.Position == "Teacher")">معلم</option>
                    <option value="Principal" selected="@(ViewBag.Position == "Principal")">مدیر</option>
                    <option value="VicePrincipal" selected="@(ViewBag.Position == "VicePrincipal")">معاون</option>
                    <option value="Counselor" selected="@(ViewBag.Position == "Counselor")">مشاور</option>
                </select>
            </div>
            <div class="form-group" style="flex:1;">
                <label>جستجو</label>
                <input name="search" value="@ViewBag.Search" class="form-control" placeholder="نام / کد پرسنلی / کد ملی / موبایل" />
            </div>
            <button class="btn btn-primary">🔍</button>
        </form>

        <div class="table-responsive">
            <table class="data-table enhanced" id="staffTable">
                <thead>
                    <tr>
                        <th>نام</th><th>کد پرسنلی</th><th>جنسیت</th>
                        <th>موبایل</th><th>نوع استخدام</th><th>مدرک</th>
                        <th>سمت‌ها</th><th>تخصیص‌ها</th><th class="no-export">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Items)
                    {
                        <tr>
                            <td>
                                <strong>@s.FullName</strong>
                                @if (!s.IsActive) {<span class="badge badge-secondary">غیرفعال</span>}
                            </td>
                            <td>@s.PersonnelCode</td>
                            <td>@s.GenderText</td>
                            <td>@s.Mobile</td>
                            <td>@s.EmploymentType</td>
                            <td>@s.Degree</td>
                            <td>
                                @foreach (var p in s.Positions)
                                {
                                    <span class="badge badge-info">
                                        @(p switch {
                                            "Teacher" => "معلم",
                                            "Principal" => "مدیر",
                                            "VicePrincipal" => "معاون",
                                            "Counselor" => "مشاور",
                                            _ => p
                                        })
                                    </span>
                                }
                            </td>
                            <td>@PersianDate.ToPersianDigits(s.AssignmentCount.ToString())</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@s.StaffId" class="btn btn-outline btn-sm">👁</a>
                                <a asp-controller="Analytics" asp-action="Teacher" asp-route-id="@s.StaffId" class="btn btn-info btn-sm" title="گزارش جامع">📊</a>
                                <a asp-action="Edit" asp-route-id="@s.StaffId" class="btn btn-primary btn-sm">✏️</a>
                                <form method="post" asp-action="Delete" asp-route-id="@s.StaffId" style="display:inline" onsubmit="return confirm('غیرفعال شود؟');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-danger btn-sm">🗑</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="9"><div class="empty-state">
                            <div class="empty-icon">👨‍🏫</div>
                            <div class="empty-text">هیچ کارمندی یافت نشد</div>
                            <a asp-action="Create" class="btn btn-primary">افزودن اولین کارمند</a>
                        </div></td></tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.Page) { <span class="active">@PersianDate.ToPersianDigits(i.ToString())</span> }
                    else { <a asp-action="Index" asp-route-page="@i" asp-route-schoolId="@ViewBag.SchoolId" asp-route-position="@ViewBag.Position" asp-route-search="@ViewBag.Search">@PersianDate.ToPersianDigits(i.ToString())</a> }
                }
            </div>
        }
    </div>
</div>

