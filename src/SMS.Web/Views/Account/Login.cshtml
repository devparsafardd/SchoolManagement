@model LoginDto
@{
    ViewData["Title"] = "ورود به سیستم";
    Layout = null;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ورود - سیستم مدیریت مدارس</title>
    <style>
        * { box-sizing: border-box; font-family: 'Vazirmatn', Tahoma, sans-serif; }
        body {
            margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
        }
        .login-container {
            background: white; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            width: 100%; max-width: 420px; overflow: hidden;
        }
        .login-header {
            background: linear-gradient(135deg, #4361ee, #3a56d4); color: white;
            padding: 30px 30px 26px; text-align: center;
        }
        .login-header .logo { font-size: 42px; margin-bottom: 8px; }
        .login-header h1 { margin: 0; font-size: 22px; font-weight: 700; }
        .login-header .subtitle { font-size: 13px; opacity: 0.9; margin-top: 4px; }
        .login-body { padding: 30px; }
        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; margin-bottom: 6px; font-size: 13px; color: #555; font-weight: 500; }
        .input-wrapper { position: relative; }
        .input-wrapper .icon {
            position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
            color: #999; pointer-events: none; font-size: 16px;
        }
        .form-control {
            width: 100%; padding: 12px 42px 12px 14px;
            border: 1.5px solid #e0e0e0; border-radius: 10px;
            font-size: 14px; transition: 0.2s;
        }
        .form-control:focus {
            outline: none; border-color: #4361ee; box-shadow: 0 0 0 3px rgba(67,97,238,0.1);
        }
        .btn-login {
            width: 100%; padding: 13px; background: linear-gradient(135deg, #4361ee, #3a56d4);
            color: white; border: none; border-radius: 10px; cursor: pointer;
            font-size: 15px; font-weight: 600; transition: 0.2s;
        }
        .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(67,97,238,0.4); }
        .alert-danger {
            background: #fde2e9; color: #9f1239; padding: 12px;
            border-radius: 10px; margin-bottom: 16px; font-size: 13px;
            border-right: 4px solid #ef476f;
        }
        .text-danger { color: #ef476f; font-size: 12px; display: block; margin-top: 4px; }
        .demo-info {
            margin-top: 20px; padding: 12px; background: #f0f4ff;
            border-radius: 10px; font-size: 12px; color: #4a5568; text-align: center;
            border: 1px dashed #4361ee;
        }
        .demo-info strong { color: #4361ee; }
        .footer {
            text-align: center; padding: 16px; background: #f8f9fc;
            font-size: 11px; color: #999;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <div class="logo">🎓</div>
            <h1>سیستم مدیریت مدارس</h1>
            <div class="subtitle">به پنل مدیریت خوش آمدید</div>
        </div>
        <div class="login-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-danger">
                    @foreach (var err in ViewData.ModelState.SelectMany(m => m.Value!.Errors))
                    {
                        <div>⚠ @err.ErrorMessage</div>
                    }
                </div>
            }
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label>نام کاربری</label>
                    <div class="input-wrapper">
                        <span class="icon">👤</span>
                        <input asp-for="Username" class="form-control" autocomplete="username" autofocus />
                    </div>
                </div>
                <div class="form-group">
                    <label>رمز عبور</label>
                    <div class="input-wrapper">
                        <span class="icon">🔒</span>
                        <input asp-for="Password" type="password" class="form-control" autocomplete="current-password" />
                    </div>
                </div>
                <button type="submit" class="btn-login">ورود به سیستم</button>
            </form>
            <div class="demo-info">
                <strong>کاربر آزمایشی</strong><br />
                نام کاربری: <code>admin</code> | رمز: <code>Admin@@123</code>
            </div>
        </div>
        <div class="footer">© @DateTime.Now.Year - تمامی حقوق محفوظ است</div>
    </div>
</body>
</html>
