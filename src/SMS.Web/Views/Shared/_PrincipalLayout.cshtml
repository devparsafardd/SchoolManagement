@using System.Reflection
@{
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "مدیر";
    var initials = string.IsNullOrEmpty(fullName) ? "?" : fullName.Substring(0, Math.Min(2, fullName.Length));
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    // ===== پیدا کردن schoolId از چندین منبع =====
    string? schoolId = ViewContext.RouteData.Values["schoolId"]?.ToString();
    if (string.IsNullOrEmpty(schoolId))
        schoolId = Context.Request.Query["schoolId"].ToString();
    if (string.IsNullOrEmpty(schoolId) && ViewBag.SchoolId != null)
        schoolId = ViewBag.SchoolId.ToString();
    if (string.IsNullOrEmpty(schoolId) && Model != null)
    {
        var prop = Model.GetType().GetProperty("SchoolId");
        if (prop != null)
        {
            var val = prop.GetValue(Model);
            if (val != null) schoolId = val.ToString();
        }
    }
    if (string.IsNullOrEmpty(schoolId))
        schoolId = Context.Session.GetString("PrincipalSchoolId");

    if (!string.IsNullOrEmpty(schoolId))
        Context.Session.SetString("PrincipalSchoolId", schoolId);
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل مدیر مدرسه</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- اعمال تم قبل از رندر -->
    <script>
        (function() {
            var t = (document.cookie.match(/sms\.theme=([^;]+)/) || [])[1] || 'indigo';
            var m = (document.cookie.match(/sms\.mode=([^;]+)/) || [])[1] || 'light';
            document.documentElement.setAttribute('data-theme', t);
            document.documentElement.setAttribute('data-mode', m);
        })();
    </script>
</head>
<body>
    <header class="topbar">
        <div class="topbar-left">
            <button class="sidebar-toggle" onclick="smsToggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            <div class="brand">
                <span class="brand-icon"><i class="bi bi-building"></i></span>
                <span class="brand-text">پنل مدیر مدرسه</span>
            </div>
        </div>
        <div class="topbar-right">
            @await Html.PartialAsync("_ThemeSwitcher")
            @await Html.PartialAsync("_NotificationBell")
                <div class="user-menu" onclick="this.classList.toggle('open')">
                @await Html.PartialAsync("_UserAvatar")
                <div class="user-info">
                    <div class="user-name">@fullName</div>
                    <div class="user-role">مدیر مدرسه</div>
                </div>
                <div class="user-dropdown">
                    <a asp-controller="Account" asp-action="Profile"><i class="bi bi-person-circle"></i> پروفایل من</a>
                    <a asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-lock-fill"></i> تغییر رمز</a>
                    <a asp-controller="Principal" asp-action="Index"><i class="bi bi-arrow-repeat"></i> تغییر مدرسه</a>
                    <hr />
                    <a asp-controller="Help" asp-action="Index"><i class="bi bi-question-circle"></i> راهنما</a>
                    <a asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> خروج</a>
                </div>
            </div>
        </div>
    </header>

    <aside class="sidebar">
        <nav class="menu">
            <a asp-controller="Principal" asp-action="Dashboard" asp-route-schoolId="@schoolId"
               class="menu-item @(currentAction == "Dashboard" ? "active" : "")">
                <i class="menu-icon bi bi-bar-chart-line-fill"></i><span class="menu-text">داشبورد مدرسه</span>
            </a>

            <div class="menu-section">مدیریت مدرسه</div>
            <a asp-controller="Principal" asp-action="Classrooms" asp-route-schoolId="@schoolId"
               class="menu-item @(currentAction == "Classrooms" ? "active" : "")">
                <i class="menu-icon bi bi-book-half"></i><span class="menu-text">کلاس‌ها</span>
            </a>
            <a asp-controller="Students" asp-action="Index" asp-route-schoolId="@schoolId"
               class="menu-item">
                <i class="menu-icon bi bi-people-fill"></i><span class="menu-text">دانش‌آموزان</span>
            </a>
            <a asp-controller="Staff" asp-action="Index" asp-route-schoolId="@schoolId"
               class="menu-item">
                <i class="menu-icon bi bi-person-workspace"></i><span class="menu-text">معلمان و کارکنان</span>
            </a>
            <a asp-controller="Guardians" asp-action="Index"
               class="menu-item">
                <i class="menu-icon bi bi-people"></i><span class="menu-text">اولیا</span>
            </a>

            <div class="menu-section">آموزشی</div>
            <a asp-controller="Attendance" asp-action="Index" asp-route-schoolId="@schoolId"
               class="menu-item">
                <i class="menu-icon bi bi-check-circle-fill"></i><span class="menu-text">حضور و غیاب</span>
            </a>
            <a asp-controller="Exams" asp-action="Browse" asp-route-schoolId="@schoolId"
               class="menu-item">
                <i class="menu-icon bi bi-pencil-square"></i><span class="menu-text">آزمون و نمره</span>
            </a>
            <a asp-controller="Discipline" asp-action="Index"
               class="menu-item">
                <i class="menu-icon bi bi-star-fill"></i><span class="menu-text">انضباطی</span>
            </a>
            <a asp-controller="Reports" asp-action="Index" asp-route-schoolId="@schoolId"
               class="menu-item">
                <i class="menu-icon bi bi-clipboard-data"></i><span class="menu-text">کارنامه و گزارش</span>
            </a>

            <div class="menu-section">مالی و ارتباطی</div>
            <a asp-controller="Finance" asp-action="Index" asp-route-schoolId="@schoolId"
               class="menu-item">
                <i class="menu-icon bi bi-cash-stack"></i><span class="menu-text">شهریه و فاکتور</span>
            </a>
            <a asp-controller="Announcements" asp-action="Index"
               class="menu-item">
                <i class="menu-icon bi bi-megaphone-fill"></i><span class="menu-text">اعلان‌ها</span>
            </a>
            <a asp-controller="Calendar" asp-action="Index"
               class="menu-item @(currentController == "Calendar" ? "active" : "")">
                <i class="menu-icon bi bi-calendar3"></i><span class="menu-text">تقویم</span>
            </a>
            <a asp-controller="Surveys" asp-action="Index"
               class="menu-item @(currentController == "Surveys" ? "active" : "")">
                <i class="menu-icon bi bi-bar-chart-line-fill"></i><span class="menu-text">نظرسنجی</span>
            </a>
            <a asp-controller="Sms" asp-action="Index"
               class="menu-item">
                <i class="menu-icon bi bi-phone-fill"></i><span class="menu-text">پیامک</span>
            </a>
            <a asp-controller="Messages" asp-action="Index"
               class="menu-item">
                <i class="menu-icon bi bi-chat-dots-fill"></i><span class="menu-text">پیام‌ها</span>
            </a>
            <a asp-controller="Analytics" asp-action="Index"
               class="menu-item">
                <i class="menu-icon bi bi-bar-chart-line-fill"></i><span class="menu-text">گزارش‌ها و آمار</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <small>پنل مدیر | نسخه ۲.۰</small>
        </div>
    </aside>

    <main class="main-content">
        @if (TempData["Success"] is string ok)
        {
            <div class="alert alert-success alert-dismissible">
                <span class="alert-icon">✓</span><span>@ok</span>
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger alert-dismissible">
                <span class="alert-icon">✗</span><span>@err</span>
                <button class="alert-close" onclick="this.parentElement.remove()">×</button>
            </div>
        }
        @RenderBody()
    </main>

    <div class="sidebar-overlay" onclick="document.body.classList.remove('sidebar-open')"></div>

    <script>
        document.addEventListener('click', function (e) {
            const menu = document.querySelector('.user-menu.open');
            if (menu && !menu.contains(e.target)) menu.classList.remove('open');
        });
    </script>
    @await Html.PartialAsync("_AdvancedScripts")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
