@using SMS.Application.DTOs
@model CalendarEventCreateDto
@{ ViewData["Title"] = "افزودن رویداد"; }

<div class="page-header"><h1>➕ رویداد جدید</h1></div>

<div class="card">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>عنوان *</label>
                <input asp-for="Title" class="form-control" required />
            </div>

            <div class="form-group">
                <label>توضیحات</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>تاریخ شروع *</label>
                    <input asp-for="StartDate" type="date" class="form-control" required />
                </div>
                <div class="form-group">
                    <label>تاریخ پایان *</label>
                    <input asp-for="EndDate" type="date" class="form-control" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>نوع رویداد *</label>
                    <select asp-for="EventType" class="form-control">
                        <option value="Other">سایر</option>
                        <option value="Holiday">تعطیلی</option>
                        <option value="Exam">آزمون</option>
                        <option value="Trip">اردو</option>
                        <option value="Meeting">جلسه اولیا</option>
                        <option value="Ceremony">مراسم</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>مخاطب</label>
                    <select asp-for="TargetAudience" class="form-control">
                        <option value="All">همه</option>
                        <option value="Students">دانش‌آموزان</option>
                        <option value="Parents">اولیا</option>
                        <option value="Teachers">معلمان</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>رنگ (اختیاری)</label>
                    <input asp-for="Color" type="color" class="form-control" style="height:42px" value="#0d6efd" />
                </div>
            </div>

            <div class="form-group">
                <label>محدوده مدرسه (اختیاری)</label>
                <select asp-for="SchoolId" class="form-control">
                    <option value="">همه مدارس</option>
                    @foreach (var s in (List<SchoolDto>)ViewBag.Schools)
                    {
                        <option value="@s.SchoolId">@s.Name</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>
                    <input asp-for="SendNotification" type="checkbox" /> ارسال نوتیفیکیشن به مخاطبان
                </label>
            </div>

            <button class="btn btn-success">💾 ثبت رویداد</button>
            <a asp-action="Index" class="btn btn-secondary">انصراف</a>
        </form>
    </div>
</div>
