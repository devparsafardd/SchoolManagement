@using SMS.Shared.Helpers
@model List<StudentScoreRow>
@{ ViewData["Title"] = "نمرات من"; }

<div class="page-header">
    <h1>📝 نمرات</h1>
    <a asp-action="Dashboard" asp-route-studentId="@ViewBag.StudentId" class="btn btn-secondary">بازگشت</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="filters-bar">
            <input type="hidden" name="studentId" value="@ViewBag.StudentId" />
            <div class="form-group">
                <label>نوبت</label>
                <select name="termId" class="form-control" onchange="this.form.submit()">
                    <option value="">همه نوبت‌ها</option>
                    @foreach (var t in (List<LookupDto>)ViewBag.Terms)
                    {
                        var sel = ViewBag.TermId != null && (int)ViewBag.TermId == t.Id ? "selected" : "";
                        @Html.Raw($"<option value='{t.Id}' {sel}>{t.Name}</option>")
                    }
                </select>
            </div>
        </form>

        <table class="data-table">
            <thead><tr><th>تاریخ</th><th>درس</th><th>معلم</th><th>نوع</th><th>عنوان آزمون</th><th>نمره</th><th>توضیح</th></tr></thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@PersianDate.ToPersian(s.ExamDate)</td>
                        <td><strong>@s.SubjectName</strong></td>
                        <td>@s.TeacherName</td>
                        <td><span class="badge badge-info">@s.ExamTypeName</span></td>
                        <td>@s.ExamTitle</td>
                        <td>
                            @if (s.IsAbsent)
                            {<span class="badge badge-danger">غایب</span>}
                            else if (s.IsExempt)
                            {<span class="badge badge-warning">معاف</span>}
                            else if (s.IsDescriptive)
                            {<span class="badge badge-info">@s.DescriptiveLabel</span>}
                            else if (s.NumericScore.HasValue)
                            {
                                var color = s.NumericScore >= (s.MaxScore ?? 20) / 2 ? "badge-success" : "badge-danger";
                                <span class="badge @color" style="font-size:13px">@PersianDate.ToPersianDigits(s.NumericScore.Value.ToString("0.##"))</span>
                                <small class="text-muted">/ @s.MaxScore</small>
                            }
                            else
                            {<span class="text-muted">—</span>}
                        </td>
                        <td>@s.Comment</td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="7" class="empty-state">نمره‌ای ثبت نشده</td></tr> }
            </tbody>
        </table>
    </div>
</div>
