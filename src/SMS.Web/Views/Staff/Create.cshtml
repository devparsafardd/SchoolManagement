@model StaffCreateDto
@{ ViewData["Title"] = "افزودن کارمند"; }

<div class="page-header"><h1>➕ افزودن کارمند جدید</h1></div>

<div class="card">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <h3 class="section-title">📌 اطلاعات شخصی</h3>
            <div class="form-row">
                <div class="form-group"><label>نام <span class="required">*</span></label><input asp-for="FirstName" class="form-control" /></div>
                <div class="form-group"><label>نام خانوادگی <span class="required">*</span></label><input asp-for="LastName" class="form-control" /></div>
                <div class="form-group"><label>نام پدر</label><input asp-for="FatherName" class="form-control" /></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label>کد ملی</label><input asp-for="NationalCode" class="form-control" maxlength="10" /></div>
                <div class="form-group"><label>جنسیت <span class="required">*</span></label>
                    <select asp-for="Gender" class="form-control"><option value="M">آقا</option><option value="F">خانم</option></select>
                </div>
                <div class="form-group"><label>تاریخ تولد</label><input asp-for="BirthDate" class="form-control" type="date" /></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label>موبایل</label><input asp-for="Mobile" class="form-control" placeholder="09xxxxxxxxx" /></div>
                <div class="form-group"><label>ایمیل</label><input asp-for="Email" class="form-control" type="email" /></div>
            </div>
            <div class="form-group"><label>آدرس</label><textarea asp-for="Address" class="form-control" rows="2"></textarea></div>

            <h3 class="section-title">💼 اطلاعات شغلی</h3>
            <div class="form-row">
                <div class="form-group"><label>کد پرسنلی</label><input asp-for="PersonnelCode" class="form-control" /></div>
                <div class="form-group"><label>نوع استخدام</label>
                    <select asp-for="EmploymentType" class="form-control">
                        <option value="">انتخاب</option>
                        <option>رسمی</option><option>پیمانی</option>
                        <option>حق‌التدریس</option><option>قراردادی</option>
                    </select>
                </div>
                <div class="form-group"><label>تاریخ استخدام</label><input asp-for="HireDate" class="form-control" type="date" /></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label>مدرک تحصیلی</label>
                    <select asp-for="Degree" class="form-control">
                        <option value="">انتخاب</option>
                        <option>دیپلم</option><option>فوق دیپلم</option>
                        <option>لیسانس</option><option>فوق لیسانس</option><option>دکتری</option>
                    </select>
                </div>
                <div class="form-group"><label>رشته تحصیلی</label><input asp-for="FieldOfStudy" class="form-control" /></div>
                <div class="form-group"><label>شماره شبا (IR + 24 رقم)</label><input asp-for="IBAN" class="form-control" /></div>
            </div>

            <h3 class="section-title">🔐 ایجاد حساب کاربری (اختیاری)</h3>
            <div class="form-group">
                <label><input asp-for="CreateUserAccount" type="checkbox" onchange="document.getElementById('userBox').style.display = this.checked ? 'block' : 'none'" /> برای این کارمند حساب کاربری ایجاد شود</label>
            </div>
            <div id="userBox" style="display:none;">
                <div class="form-row">
                    <div class="form-group"><label>نام کاربری</label><input asp-for="Username" class="form-control" /></div>
                    <div class="form-group"><label>رمز عبور</label><input asp-for="Password" type="password" class="form-control" /></div>
                </div>
            </div>

            <button type="submit" class="btn btn-success">💾 ثبت کارمند</button>
            <a asp-action="Index" class="btn btn-secondary">انصراف</a>
        </form>
    </div>
</div>
