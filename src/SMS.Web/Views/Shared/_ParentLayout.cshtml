@{
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "ولی";
    var initials = string.IsNullOrEmpty(fullName) ? "?" : fullName.Substring(0, Math.Min(2, fullName.Length));
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل ولی</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- اعمال تم قبل از رندر -->
    <script>
        (function() {
            var t = (document.cookie.match(/sms\.theme=([^;]+)/) || [])[1] || 'indigo';
            var m = (document.cookie.match(/sms\.mode=([^;]+)/) || [])[1] || 'light';
            document.documentElement.setAttribute('data-theme', t);
            document.documentElement.setAttribute('data-mode', m);
        })();
    </script>
</head>
<body>
    <header class="topbar">
        <div class="topbar-left">
            <button class="sidebar-toggle" onclick="smsToggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            <div class="brand">
                <span class="brand-icon"><i class="bi bi-people"></i></span>
                <span class="brand-text">پنل ولی</span>
            </div>
        </div>
        <div class="topbar-right">
            @await Html.PartialAsync("_ThemeSwitcher")
            @await Html.PartialAsync("_NotificationBell")
                <div class="user-menu" onclick="this.classList.toggle('open')">
                @await Html.PartialAsync("_UserAvatar")
                <div class="user-info">
                    <div class="user-name">@fullName</div>
                    <div class="user-role">ولی دانش‌آموز</div>
                </div>
                <div class="user-dropdown">
                    <a asp-controller="Account" asp-action="Profile"><i class="bi bi-person-circle"></i> پروفایل من</a>
                    <a asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-lock-fill"></i> تغییر رمز</a>
                    <hr />
                    <a asp-controller="Help" asp-action="Index"><i class="bi bi-question-circle"></i> راهنما</a>
                    <a asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> خروج</a>
                </div>
            </div>
        </div>
    </header>

    <aside class="sidebar">
        <nav class="menu">
            <a asp-controller="Parent" asp-action="Dashboard"
               class="menu-item @(currentAction == "Dashboard" || currentAction == "Index" ? "active" : "")">
                <i class="menu-icon bi bi-house-door-fill"></i><span class="menu-text">فرزندان من</span>
            </a>

            <div class="menu-section">ارتباطات</div>
            <a asp-controller="Announcements" asp-action="Index" class="menu-item">
                <i class="menu-icon bi bi-megaphone-fill"></i><span class="menu-text">اعلان‌ها</span>
            </a>
            <a asp-controller="Calendar" asp-action="Index" class="menu-item">
                <i class="menu-icon bi bi-calendar3"></i><span class="menu-text">تقویم</span>
            </a>
            <a asp-controller="Surveys" asp-action="Index" class="menu-item">
                <i class="menu-icon bi bi-bar-chart-line-fill"></i><span class="menu-text">نظرسنجی</span>
            </a>
            <a asp-controller="Messages" asp-action="Index" class="menu-item">
                <i class="menu-icon bi bi-chat-dots-fill"></i><span class="menu-text">پیام‌ها</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <small>پنل ولی | نسخه ۲.۰</small>
        </div>
    </aside>

    <main class="main-content">
        @if (TempData["Success"] is string ok)
        {
            <div class="alert alert-success">@ok</div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger">@err</div>
        }
        @RenderBody()
    </main>

    <div class="sidebar-overlay" onclick="document.body.classList.remove('sidebar-open')"></div>

    <script>
        document.addEventListener('click', function (e) {
            const menu = document.querySelector('.user-menu.open');
            if (menu && !menu.contains(e.target)) menu.classList.remove('open');
        });
    </script>
    @await Html.PartialAsync("_AdvancedScripts")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
