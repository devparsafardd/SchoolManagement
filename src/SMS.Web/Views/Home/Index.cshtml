@using SMS.Shared.Helpers
@{
    ViewData["Title"] = "داشبورد";
    var today = PersianDate.ToPersianLong(DateTime.Now);
}

@section Styles { <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script> }

<div class="page-header">
    <div>
        <h1><i class="bi bi-bar-chart-line-fill"></i>داشبورد مدیریت</h1>
        <div class="subtitle">@today</div>
    </div>
    <div>
        <a asp-controller="Analytics" asp-action="Index" class="btn btn-primary">📈 گزارش‌های جامع</a>
    </div>
</div>

<!-- آمار کلی -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">مدارس فعال</div>
            <div class="stat-number">@PersianDate.ToPersianDigits(((int)ViewBag.SchoolCount).ToString())</div>
        </div>
        <div class="stat-icon bg-primary"><i class="bi bi-building"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">دانش‌آموزان</div>
            <div class="stat-number">@PersianDate.ToPersianDigits(((int)ViewBag.StudentCount).ToString())</div>
        </div>
        <div class="stat-icon bg-success"><i class="bi bi-people-fill"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">معلمان و کارکنان</div>
            <div class="stat-number">@PersianDate.ToPersianDigits(((int)ViewBag.StaffCount).ToString())</div>
        </div>
        <div class="stat-icon bg-info"><i class="bi bi-person-workspace"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">کلاس‌ها</div>
            <div class="stat-number">@PersianDate.ToPersianDigits(((int)ViewBag.ClassroomCount).ToString())</div>
        </div>
        <div class="stat-icon bg-warning"><i class="bi bi-book-half"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">حضور امروز</div>
            <div class="stat-number">@PersianDate.ToPersianDigits(((int)ViewBag.TodayAttendanceCount).ToString())</div>
            <div class="stat-trend text-danger">@PersianDate.ToPersianDigits(((int)ViewBag.TodayAbsentCount).ToString()) غایب</div>
        </div>
        <div class="stat-icon bg-success"><i class="bi bi-check-circle-fill"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">انضباطی هفته</div>
            <div class="stat-number">
                <span class="text-success">+@PersianDate.ToPersianDigits(((int)ViewBag.WeekRewardCount).ToString())</span>
                /
                <span class="text-danger">-@PersianDate.ToPersianDigits(((int)ViewBag.WeekPunishmentCount).ToString())</span>
            </div>
        </div>
        <div class="stat-icon bg-info"><i class="bi bi-star-fill"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">درآمد کل</div>
            <div class="stat-number">@PersianDate.ToPersianDigits(((decimal)ViewBag.TotalPaid).ToString("N0"))</div>
            <div class="stat-trend text-muted">@PersianDate.ToPersianDigits(((decimal)ViewBag.CollectionRate).ToString("0.0"))% وصولی</div>
        </div>
        <div class="stat-icon bg-success"><i class="bi bi-cash-stack"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">معوقات</div>
            <div class="stat-number text-danger">@PersianDate.ToPersianDigits(((decimal)ViewBag.TotalDebt).ToString("N0"))</div>
            <div class="stat-trend text-muted">تومان</div>
        </div>
        <div class="stat-icon bg-danger"><i class="bi bi-exclamation-triangle-fill"></i></div>
    </div>
</div>

<!-- دسترسی‌های سریع -->
<div class="card" style="margin-top:16px">
    <div class="card-header"><h2>⚡ دسترسی سریع</h2></div>
    <div class="card-body">
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(170px, 1fr)); gap:10px">
            <a asp-controller="Students" asp-action="Create" class="btn btn-outline" style="padding:14px"><div>👤</div>افزودن دانش‌آموز</a>
            <a asp-controller="Staff" asp-action="Create" class="btn btn-outline" style="padding:14px"><div>👨‍🏫</div>افزودن کارمند</a>
            <a asp-controller="Classrooms" asp-action="Index" class="btn btn-outline" style="padding:14px"><div>📚</div>مدیریت کلاس‌ها</a>
            <a asp-controller="Attendance" asp-action="Index" class="btn btn-outline" style="padding:14px"><div>✅</div>حضور و غیاب</a>
            <a asp-controller="Exams" asp-action="Browse" class="btn btn-outline" style="padding:14px"><div>📝</div>آزمون‌ها</a>
            <a asp-controller="Finance" asp-action="Index" class="btn btn-outline" style="padding:14px"><div>💰</div>مالی</a>
            <a asp-controller="Reports" asp-action="Index" class="btn btn-outline" style="padding:14px"><div>📋</div>کارنامه</a>
            <a asp-controller="Analytics" asp-action="Attendance" class="btn btn-outline" style="padding:14px"><div>📊</div>تحلیل حضور</a>
            <a asp-controller="Schedules" asp-action="Periods" class="btn btn-outline" style="padding:14px"><div>⏰</div>زنگ‌بندی</a>
            <a asp-controller="Sms" asp-action="SendBulk" class="btn btn-outline" style="padding:14px"><div>📱</div>پیامک گروهی</a>
        </div>
    </div>
</div>

<!-- نمودارها -->
<div class="row" style="display:grid; grid-template-columns:2fr 1fr; gap:16px; margin-top:16px">
    <div class="card">
        <div class="card-header"><h2><i class="bi bi-graph-up"></i>روند حضور و غیاب ۷ روز اخیر</h2></div>
        <div class="card-body"><canvas id="attChart" height="90"></canvas></div>
    </div>
    <div class="card">
        <div class="card-header"><h2><i class="bi bi-pie-chart-fill"></i>توزیع دانش‌آموز در مدارس</h2></div>
        <div class="card-body"><canvas id="schoolChart" height="220"></canvas></div>
    </div>
</div>

<div class="row" style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:16px">
    <div class="card">
        <div class="card-header"><h2><i class="bi bi-people-fill"></i>توزیع نقش‌ها</h2></div>
        <div class="card-body">
            <table class="data-table">
                <thead><tr><th>نقش</th><th>تعداد</th></tr></thead>
                <tbody>
                    @foreach (var r in (dynamic)ViewBag.RoleDistribution)
                    {
                        <tr>
                            <td>@r.Role</td>
                            <td><strong>@PersianDate.ToPersianDigits(((int)r.Count).ToString())</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><h2><i class="bi bi-stars"></i>ثبت‌نام‌های اخیر</h2></div>
        <div class="card-body" style="max-height:300px; overflow-y:auto">
            <ul style="list-style:none; padding:0; margin:0">
                @foreach (var e in (dynamic)ViewBag.RecentEnrollments)
                {
                    <li style="padding:8px 0; border-bottom:1px solid #eee">
                        <strong>@e.StudentName</strong>
                        <small class="text-muted"> در @e.ClassName | @e.SchoolName</small>
                        <span style="float:left; color:#999; font-size:0.85em">@PersianDate.ToPersian((DateTime)e.Date)</span>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        new Chart(document.getElementById('attChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AttLabels)),
                datasets: [
                    { label: 'حاضر', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AttPresent)), borderColor:'#198754', backgroundColor:'#19875422', fill:true, tension:0.3 },
                    { label: 'غایب', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AttAbsent)), borderColor:'#dc3545', backgroundColor:'#dc354522', fill:true, tension:0.3 },
                    { label: 'تاخیر', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AttTardy)), borderColor:'#ffc107', backgroundColor:'#ffc10722', fill:true, tension:0.3 }
                ]
            },
            options: { responsive:true, plugins:{ legend:{ position:'bottom' } } }
        });

        new Chart(document.getElementById('schoolChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((IEnumerable<dynamic>)ViewBag.SchoolDistribution).Select(s => (string)s.Name))),
                datasets: [{
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((IEnumerable<dynamic>)ViewBag.SchoolDistribution).Select(s => (int)s.Count))),
                    backgroundColor:['#6f42c1','#0d6efd','#198754','#ffc107','#dc3545','#fd7e14','#20c997','#6610f2']
                }]
            },
            options: { responsive:true, plugins:{ legend:{ position:'bottom' } } }
        });
    </script>
}
