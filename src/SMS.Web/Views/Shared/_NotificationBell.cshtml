@using SMS.Application.Services
@inject IMessageService MsgSvc
@inject SMS.Application.Common.ICurrentUserService CurrentUser
@{
    var userId = CurrentUser.UserId;
    int unread = 0;
    if (userId.HasValue)
    {
        try { unread = await MsgSvc.GetUnreadCountAsync(userId.Value); } catch { }
    }
}
<a asp-controller="Messages" asp-action="Index" class="topbar-btn" title="پیام‌های جدید">
    <i class="bi bi-bell-fill"></i>
    @if (unread > 0)
    {
        <span class="badge-dot">@(unread > 99 ? "99+" : unread.ToString())</span>
    }
</a>
