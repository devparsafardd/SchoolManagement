@model StaffUpdateDto
@{ ViewData["Title"] = "ویرایش کارمند"; }

<div class="page-header"><h1>✏️ ویرایش کارمند</h1></div>

<div class="card">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="StaffId" />
            <input type="hidden" asp-for="PersonId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <h3 class="section-title">📌 اطلاعات شخصی</h3>
            <div class="form-row">
                <div class="form-group"><label>نام</label><input asp-for="FirstName" class="form-control" /></div>
                <div class="form-group"><label>نام خانوادگی</label><input asp-for="LastName" class="form-control" /></div>
                <div class="form-group"><label>نام پدر</label><input asp-for="FatherName" class="form-control" /></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label>کد ملی</label><input asp-for="NationalCode" class="form-control" /></div>
                <div class="form-group"><label>جنسیت</label>
                    <select asp-for="Gender" class="form-control"><option value="M">آقا</option><option value="F">خانم</option></select>
                </div>
                <div class="form-group"><label>موبایل</label><input asp-for="Mobile" class="form-control" /></div>
                <div class="form-group"><label>ایمیل</label><input asp-for="Email" class="form-control" /></div>
            </div>

            <h3 class="section-title">💼 اطلاعات شغلی</h3>
            <div class="form-row">
                <div class="form-group"><label>کد پرسنلی</label><input asp-for="PersonnelCode" class="form-control" /></div>
                <div class="form-group"><label>نوع استخدام</label><input asp-for="EmploymentType" class="form-control" /></div>
                <div class="form-group"><label>تاریخ استخدام</label><input asp-for="HireDate" class="form-control" type="date" /></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label>مدرک تحصیلی</label><input asp-for="Degree" class="form-control" /></div>
                <div class="form-group"><label>رشته تحصیلی</label><input asp-for="FieldOfStudy" class="form-control" /></div>
                <div class="form-group"><label>وضعیت</label>
                    <select asp-for="IsActive" class="form-control"><option value="true">فعال</option><option value="false">غیرفعال</option></select>
                </div>
            </div>

            <button type="submit" class="btn btn-success">💾 ذخیره</button>
            <a asp-action="Index" class="btn btn-secondary">انصراف</a>
        </form>
    </div>
</div>
