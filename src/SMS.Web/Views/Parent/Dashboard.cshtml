@using SMS.Application.DTOs
@using SMS.Shared.Helpers
@model List<ChildSummaryDto>
@{ ViewData["Title"] = "فرزندان من"; }

<div class="page-header">
    <h1><i class="bi bi-people"></i>فرزندان من</h1>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        هیچ فرزندی به حساب شما متصل نیست. لطفاً با مدرسه تماس بگیرید.
    </div>
}
else
{
    <!-- آمار سریع -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">تعداد فرزندان</div>
                <div class="stat-number">@PersianDate.ToPersianDigits(Model.Count.ToString())</div>
            </div>
            <div class="stat-icon bg-primary">👶</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">مجموع غیبت اخیر</div>
                <div class="stat-number">@PersianDate.ToPersianDigits(Model.Sum(c => c.RecentAbsences).ToString())</div>
            </div>
            <div class="stat-icon bg-warning"><i class="bi bi-x-circle"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">میانگین کلی</div>
                <div class="stat-number">
                    @{
                        var avg = Model.Where(c => c.CurrentGPA.HasValue).Select(c => c.CurrentGPA!.Value).DefaultIfEmpty(0).Average();
                    }
                    @PersianDate.ToPersianDigits(avg.ToString("0.00"))
                </div>
            </div>
            <div class="stat-icon bg-success"><i class="bi bi-bar-chart-line-fill"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">کل بدهی</div>
                <div class="stat-number text-danger">
                    @PersianDate.ToPersianDigits(Model.Sum(c => c.RemainingDebt).ToString("N0"))
                </div>
                <div class="stat-trend text-muted">تومان</div>
            </div>
            <div class="stat-icon bg-danger"><i class="bi bi-cash-stack"></i></div>
        </div>
    </div>

    <!-- کارت‌های فرزندان -->
    <h2 style="margin-top:24px">📋 جزئیات فرزندان</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:16px">
        @foreach (var c in Model)
        {
            <div class="card">
                <div class="card-body">
                    <div style="display:flex; align-items:center; gap:12px">
                        <div style="width:60px; height:60px; border-radius:50%; background:#fd7e14; color:white; display:flex; align-items:center; justify-content:center; font-size:24px; font-weight:bold">
                            @(c.FullName.Substring(0, Math.Min(2, c.FullName.Length)))
                        </div>
                        <div>
                            <h3 style="margin:0">@c.FullName</h3>
                            <div class="text-muted" style="font-size:0.9em">
                                کد: @PersianDate.ToPersianDigits(c.StudentCode)
                            </div>
                        </div>
                    </div>

                    <div style="margin-top:14px; font-size:0.9em">
                        <div>🏫 @c.SchoolName</div>
                        <div>📚 @c.ClassroomName</div>
                    </div>

                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:14px; text-align:center">
                        <div style="background:#f8f9fa; padding:8px; border-radius:6px">
                            <div class="text-muted" style="font-size:0.75em">معدل</div>
                            <strong>@(c.CurrentGPA.HasValue ? PersianDate.ToPersianDigits(c.CurrentGPA.Value.ToString("0.00")) : "—")</strong>
                        </div>
                        <div style="background:#f8f9fa; padding:8px; border-radius:6px">
                            <div class="text-muted" style="font-size:0.75em">غیبت اخیر</div>
                            <strong class="@(c.RecentAbsences > 3 ? "text-danger" : "")">
                                @PersianDate.ToPersianDigits(c.RecentAbsences.ToString())
                            </strong>
                        </div>
                        <div style="background:#f8f9fa; padding:8px; border-radius:6px">
                            <div class="text-muted" style="font-size:0.75em">بدهی</div>
                            <strong class="@(c.RemainingDebt > 0 ? "text-danger" : "text-success")" style="font-size:0.85em">
                                @PersianDate.ToPersianDigits(c.RemainingDebt.ToString("N0"))
                            </strong>
                        </div>
                    </div>

                    <a asp-action="View" asp-route-studentId="@c.StudentId"
                       class="btn btn-primary" style="width:100%; margin-top:14px"><i class="bi bi-search"></i> مشاهده جزئیات
                    </a>
                    <a asp-controller="Analytics" asp-action="Student" asp-route-id="@c.StudentId"
                       class="btn btn-info" style="width:100%; margin-top:6px"><i class="bi bi-bar-chart"></i> گزارش جامع و نمودارها
                    </a>
                </div>
            </div>
        }
    </div>
}
