@using SMS.Application.DTOs
@using SMS.Shared.Helpers
@model AttendanceAnalyticsDto
@{ ViewData["Title"] = "تحلیل حضور و غیاب"; }

@section Styles { <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script> }

<div class="page-header">
    <h1>📅 تحلیل حضور و غیاب</h1>
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="filters-bar">
            <div class="form-group">
                <label>مدرسه</label>
                <select name="schoolId" class="form-control">
                    <option value="">همه</option>
                    @foreach (var s in (List<SchoolDto>)ViewBag.Schools)
                    {
                        var sel = (int?)ViewBag.SchoolId == s.SchoolId ? "selected" : "";
                        @Html.Raw($"<option value='{s.SchoolId}' {sel}>{s.Name}</option>")
                    }
                </select>
            </div>
            <div class="form-group">
                <label>از تاریخ</label>
                <input name="fromDate" value="@ViewBag.FromDate" class="form-control persian-date" autocomplete="off" placeholder="1404/01/01" style="width:120px" />
            </div>
            <div class="form-group">
                <label>تا تاریخ</label>
                <input name="toDate" value="@ViewBag.ToDate" class="form-control persian-date" autocomplete="off" placeholder="1404/12/29" style="width:120px" />
            </div>
            <button class="btn btn-primary">🔍 مشاهده</button>
        </form>
    </div>
</div>

<div class="stats-grid" style="margin-top:16px">
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">کل ثبت‌ها</div>
            <div class="stat-number">@PersianDate.ToPersianDigits(Model.TotalRecords.ToString())</div>
        </div>
        <div class="stat-icon bg-primary">📊</div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">حاضر</div>
            <div class="stat-number text-success">@PersianDate.ToPersianDigits(Model.PresentCount.ToString())</div>
            <div class="stat-trend">@PersianDate.ToPersianDigits(Model.PresentRate.ToString("0.0"))%</div>
        </div>
        <div class="stat-icon bg-success">✓</div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">غایب</div>
            <div class="stat-number text-danger">@PersianDate.ToPersianDigits(Model.AbsentCount.ToString())</div>
            <div class="stat-trend">@PersianDate.ToPersianDigits(Model.AbsentRate.ToString("0.0"))%</div>
        </div>
        <div class="stat-icon bg-danger">✗</div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <div class="stat-label">تاخیر</div>
            <div class="stat-number text-warning">@PersianDate.ToPersianDigits(Model.TardyCount.ToString())</div>
        </div>
        <div class="stat-icon bg-warning">⏰</div>
    </div>
</div>

<div class="card" style="margin-top:16px">
    <div class="card-header"><h2>📈 روند روزانه</h2></div>
    <div class="card-body"><canvas id="dailyChart" height="80"></canvas></div>
</div>

<div class="row" style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:16px">
    <div class="card">
        <div class="card-header"><h2>🏫 آمار به تفکیک کلاس</h2></div>
        <div class="card-body" style="max-height:400px; overflow-y:auto">
            <table class="data-table">
                <thead><tr><th>کلاس</th><th>پایه</th><th>حاضر</th><th>غایب</th><th>تاخیر</th><th>%</th></tr></thead>
                <tbody>
                    @foreach (var c in Model.ByClassroom)
                    {
                        <tr>
                            <td>@c.ClassroomName</td>
                            <td>@c.GradeName</td>
                            <td class="text-success">@PersianDate.ToPersianDigits(c.PresentCount.ToString())</td>
                            <td class="text-danger">@PersianDate.ToPersianDigits(c.AbsentCount.ToString())</td>
                            <td class="text-warning">@PersianDate.ToPersianDigits(c.TardyCount.ToString())</td>
                            <td><strong>@PersianDate.ToPersianDigits(c.PresentRate.ToString("0.0"))%</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><h2>⚠️ بیشترین غیبت</h2></div>
        <div class="card-body" style="max-height:400px; overflow-y:auto">
            <table class="data-table">
                <thead><tr><th>دانش‌آموز</th><th>کلاس</th><th>غیبت</th><th>تاخیر</th></tr></thead>
                <tbody>
                    @foreach (var s in Model.TopAbsentees)
                    {
                        <tr>
                            <td>@s.FullName</td>
                            <td>@s.ClassroomName</td>
                            <td class="text-danger"><strong>@PersianDate.ToPersianDigits(s.AbsentCount.ToString())</strong></td>
                            <td>@PersianDate.ToPersianDigits(s.TardyCount.ToString())</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () { $('.persian-date').smsPersianDatePicker(); });
    </script>
    <script>
        new Chart(document.getElementById('dailyChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Daily.Select(d => d.Label))),
                datasets: [
                    { label: 'حاضر', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Daily.Select(d => d.Present))), borderColor:'#198754', backgroundColor:'#19875422', fill:true, tension:0.3 },
                    { label: 'غایب', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Daily.Select(d => d.Absent))), borderColor:'#dc3545', backgroundColor:'#dc354522', fill:true, tension:0.3 },
                    { label: 'تاخیر', data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Daily.Select(d => d.Tardy))), borderColor:'#ffc107', backgroundColor:'#ffc10722', fill:true, tension:0.3 }
                ]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });
    </script>
}

